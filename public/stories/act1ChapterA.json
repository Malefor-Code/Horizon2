      "title": "ACT 1 - CHAPTER A : BLIGHTED TRACKS",
      "text": "You stand at the edge of a dark forest.\nThe moon hangs low.",
      "information": ["Night: visibility reduced", "Wind: strong"],
      "actions": [
        { "type": "read", "target": "002", "label": "Step forward" },
        { "type": "test", "label": "Make 2 arrows", "pass": "015", "fail": "018" }
      ]
    },
    {
      "id": "002",
      "title": "A fork in the road",
      "text": "Two paths appear: one lit by lanterns, one swallowed by shadow.",
      "actions": [
        { "type": "read", "target": "003", "label": "Take left path" },
        { "type": "read", "target": "004", "label": "Take right path" }
      ]
    },
    {
      "id": "003",
      "title": "Left Path",
      "text": "A friendly traveler offers a hint.",
      "information": ["You feel slightly safer here."],
      "actions": [{ "type": "read", "target": "005", "label": "Continue" }]
    },
    {
      "id": "004",
      "title": "Right Path",
      "text": "Shadows tug at your cloak.",
      "actions": [{ "type": "read", "target": "005", "label": "Steady on" }]
    },
    {
      "id": "005",
      "title": "Crossroads",
      "text": "You arrive at a crossroads where two choices matter.",
      "actions": [
        { "type": "test", "label": "Search for traps", "pass": "006", "fail": "007" }
      ]
    },
    {
      "id": "006",
      "title": "You find a trap",
      "text": "You disarm it and move on.",
      "actions": [{ "type": "read", "target": "015", "label": "Move on" }]
    },
    {
      "id": "007",
      "title": "A misstep",
      "text": "You stumble; it's a learning moment.",
      "actions": [{ "type": "read", "target": "015", "label": "Recover" }]
    },
    {
      "id": "015",
      "title": "Success - Crafting Complete",
      "text": "You made 2 arrows successfully.",
      "information": ["Arrows: +2"],
